      ],
      "dimensions": [
        { "name": "ds", "type": "time", "type_params": { "time_granularity": "day" }, "expr": null },
        { "name": "is_instant", "type": "categorical", "expr": null }
      ]
    }
  ],
  "metrics": [
    {
      "name": "bookings",
      "type": "simple",
      "type_params": { "measure": { "name": "bookings", "join_to_timespine": false } }
    },
    {
      "name": "instant_bookings",
      "type": "simple",
      "type_params": { "measure": { "name": "instant_bookings", "join_to_timespine": false } }
    },
    {
      "name": "instant_booking_rate",
      "type": "ratio",
      "type_params": {
        "numerator": { "name": "instant_bookings", "alias": "instant_bookings" },
        "denominator": { "name": "bookings", "alias": "bookings" }
      }
    }
  ],
  "project_configuration": {
