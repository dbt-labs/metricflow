{
  "semantic_models": [
    {
      "name": "bookings_source",
      "node_relation": {
        "alias": "fct_bookings",
        "schema_name": "demo",
        "database": null
      },
      "defaults": {
        "agg_time_dimension": "ds"
      },
      "primary_entity": "booking",
      "entities": [
        { "name": "booking", "type": "primary", "expr": null }
